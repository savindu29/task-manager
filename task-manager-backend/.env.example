# Copy to .env and fill in real values. Never commit .env.

# Database (required)
DB_URL=jdbc:postgresql://localhost:5432/taskmanager
DB_USERNAME=taskuser
DB_PASSWORD=CHANGE_ME

# JWT secret: Base64, >= 256-bit (openssl rand -base64 48)
JWT_SECRET=CHANGE_ME_BASE64_ENCODED_SECRET

# Bootstrap admin (seeded on startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME
ADMIN_NAME=System Administrator

# Server port
SERVER_PORT=5000

# JPA
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# Auth cookie (Secure=true over HTTPS; SameSite=None for cross-site)
AUTH_COOKIE_NAME=access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax

# CORS: comma-separated frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000
